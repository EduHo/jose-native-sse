{
  "name": "jose-native-sse",
  "version": "0.1.0",
  "description": "Native SSE (Server-Sent Events) for React Native using TurboModules (New Architecture)",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/.gradle",
    "!example"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/ios/build lib",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "sse",
    "server-sent-events",
    "eventsource",
    "turbomodule",
    "new-architecture",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EduardoGoncalves/jose-native-sse.git"
  },
  "author": "EduHo <eduardg.geral@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EduardoGoncalves/jose-native-sse/issues"
  },
  "homepage": "https://github.com/EduardoGoncalves/jose-native-sse#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.44",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  },
  "codegenConfig": {
    "name": "RNNativeSseSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  }
}
